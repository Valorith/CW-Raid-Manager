# Nexus API host that has the /api/codex-runner endpoints deployed.
NEXUS_BASE_URL=https://nexus.clumsysworld.com

# Must match CODEX_RUNNER_TOKEN on the Nexus server.
CODEX_RUNNER_TOKEN=replace-with-a-long-random-shared-secret

# Stable label shown on Nexus job records.
CODEX_RUNNER_ID=vps-codex-runner

# Absolute path is recommended for systemd.
CODEX_RUNNER_WORK_ROOT=/home/ubuntu/nexus-codex-runner/work
CODEX_RUNNER_REGISTRY_DIR=/home/ubuntu/nexus-codex-runner/work/runners
CODEX_RUNNER_CONTROL_DIR=/home/ubuntu/nexus-codex-runner/work/runner-controls

# Local Codex CLI executable on the VPS.
CODEX_BIN=/home/ubuntu/nexus-codex-runner/node_modules/.bin/codex
CODEX_HOME=/home/ubuntu/.codex

# Execution mode:
# - local: run `codex exec` directly on the VPS checkout.
# - cloud-hybrid: submit to Codex Cloud, apply the completed diff locally, then verify and open the PR from the VPS.
CODEX_RUNNER_EXECUTION_MODE=local

# Required only when CODEX_RUNNER_EXECUTION_MODE=cloud-hybrid.
# CODEX_CLOUD_ENV_ID=env_...
# Optional per-repository override list. Use this when one runner handles multiple repos.
# CODEX_CLOUD_ENV_BY_REPO=Valorith/Server=env_...,Valorith/CW-Raid-Manager=env_...
CODEX_CLOUD_ATTEMPTS=1
CODEX_CLOUD_POLL_INTERVAL_MS=15000
CODEX_CLOUD_TIMEOUT_MS=7200000

# Polling and PR behavior.
CODEX_RUNNER_POLL_INTERVAL_MS=15000
CODEX_RUNNER_HEARTBEAT_INTERVAL_MS=5000
CODEX_RUNNER_CANCEL_CHECK_INTERVAL_MS=5000
CODEX_RUNNER_DRAFT_PR=false

# Optional final verification command run after Codex completes.
# CODEX_RUNNER_VERIFY_COMMAND=npm test

GIT_AUTHOR_NAME=Nexus Codex Runner
GIT_AUTHOR_EMAIL=codex-runner@local
