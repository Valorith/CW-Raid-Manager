# Public URL that reaches the VPS dashboard through Cloudflare Tunnel or another HTTPS proxy.
DASHBOARD_BASE_URL=https://vaylebot.com
# Optional when hosting under an existing hostname, such as https://vaylebot.com/codex.
# DASHBOARD_BASE_PATH=/codex
# Optional aliases accepted by the app during URL transitions or OAuth callback compatibility.
# DASHBOARD_BASE_PATH_ALIASES=/codex-runners
# Optional if Google OAuth still has an older callback URL authorized.
# DASHBOARD_OAUTH_BASE_PATH=/codex-runners
# Recommended when callback aliases differ from the visible dashboard path.
DASHBOARD_COOKIE_PATH=/

# Local bind. Keep this on loopback when using Cloudflare/nginx as the public edge.
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8788

# Google OAuth web client. The authorized redirect URI must be:
# https://codex-runners.vaylebot.com/auth/google/callback
# or, when hosted under /codex:
# https://vaylebot.com/codex/auth/google/callback
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# Long random secret for signed dashboard sessions.
DASHBOARD_SESSION_SECRET=replace-with-a-long-random-session-secret

# Require at least one allowlist setting. Comma-separated.
DASHBOARD_ALLOWED_EMAILS=admin@example.com
# DASHBOARD_ALLOWED_DOMAINS=example.com

# Runner heartbeat source.
CODEX_RUNNER_WORK_ROOT=/home/ubuntu/nexus-codex-runner/work
CODEX_RUNNER_REGISTRY_DIR=/home/ubuntu/nexus-codex-runner/work/runners
CODEX_RUNNER_CONTROL_DIR=/home/ubuntu/nexus-codex-runner/work/runner-controls
DASHBOARD_STALE_AFTER_MS=45000
DASHBOARD_SESSION_TTL_SECONDS=86400
DASHBOARD_LOG_LINES=240

# Nexus runner API. These are read server-side by the dashboard and are never sent to browsers.
NEXUS_BASE_URL=https://nexus.clumsysworld.com
CODEX_RUNNER_TOKEN=replace-with-the-same-secret-used-by-nexus-and-the-runner
CODEX_RUNNER_REPOSITORY=Valorith/Server
CODEX_RUNNER_BASE_BRANCH=master

# Local systemd service managed by the dashboard controls.
CODEX_RUNNER_SERVICE_NAME=nexus-codex-runner.service
