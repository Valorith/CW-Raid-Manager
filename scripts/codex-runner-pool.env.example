# Shared Nexus runner API settings. These usually match the main runner .env file.
NEXUS_BASE_URL=https://nexus.clumsysworld.com
CODEX_RUNNER_TOKEN=replace-with-the-same-secret-used-by-nexus-and-the-runners

# Pool identity. Instances will be named like vps-codex-runner-pool-1.
CODEX_RUNNER_POOL_PREFIX=vps-codex-runner-pool

# VPS-local elasticity limits. Keep max conservative until Codex/GitHub/API quotas are known.
CODEX_RUNNER_POOL_MIN=0
CODEX_RUNNER_POOL_MAX=2

# Scale target = busy pool runners + ceil(queued jobs / backlog-per-runner), clamped min/max.
CODEX_RUNNER_POOL_SCALE_UP_BACKLOG_PER_RUNNER=1

# How often the manager checks Nexus and runner heartbeats.
CODEX_RUNNER_POOL_POLL_INTERVAL_MS=15000

# Idle pool runners above target are stopped only after this idle age.
CODEX_RUNNER_POOL_IDLE_TTL_MS=600000

# Heartbeats older than this are treated as stale.
CODEX_RUNNER_POOL_STALE_AFTER_MS=60000

# Local state paths.
CODEX_RUNNER_WORK_ROOT=/home/ubuntu/nexus-codex-runner/work
CODEX_RUNNER_REGISTRY_DIR=/home/ubuntu/nexus-codex-runner/work/runners
CODEX_RUNNER_CONTROL_DIR=/home/ubuntu/nexus-codex-runner/work/runner-controls
CODEX_RUNNER_POOL_STATE_FILE=/home/ubuntu/nexus-codex-runner/work/runner-pool.json

# systemd service names.
CODEX_RUNNER_POOL_TEMPLATE_SERVICE=nexus-codex-runner@.service
CODEX_RUNNER_POOL_MANAGER_SERVICE_NAME=nexus-codex-runner-pool-manager.service

# Set true to observe decisions without starting/stopping systemd units.
CODEX_RUNNER_POOL_DRY_RUN=false
