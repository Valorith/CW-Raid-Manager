# Copy this file to .env and update values as needed
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
# Optional: live site URL used by Discord webhook links when CLIENT_URL is local.
# DISCORD_PUBLIC_CLIENT_URL=https://your-nexus-host
DATABASE_URL=mysql://user:password@localhost:3306/cw_raid_manager
SESSION_SECRET=replace-with-strong-random-string

# Passkeys (optional overrides; defaults derive from CLIENT_URL)
# PASSKEY_RP_NAME=CWRaidManager
# PASSKEY_RP_ID=localhost
# PASSKEY_ORIGIN=http://localhost:5173

# Google OAuth (optional - at least one OAuth provider required)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Discord OAuth (optional - at least one OAuth provider required)
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_CALLBACK_URL=http://localhost:4000/api/auth/discord/callback

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_WEBHOOK_URL=http://localhost:4000/api/integrations/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=replace-with-telegram-webhook-secret

# AI review escalation (optional)
OpenAI_API_KEY=your-openai-api-key
