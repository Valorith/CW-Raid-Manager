{
  "name": "cw-raid-manager",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo for CW Raid Manager application (EverQuest raid management platform).",
  "engines": {
    "node": ">=20.19.0"
  },
  "workspaces": [
    "client",
    "server",
    "cli"
  ],
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "dev:server": "npm --workspace server run dev",
    "dev:client": "npm --workspace client run dev",
    "build": "npm run build:server && npm run build:client && npm run build:cli",
    "build:server": "npm --workspace server run build",
    "build:client": "npm --workspace client run build",
    "build:cli": "npm --workspace cli run build",
    "start": "npm --workspace server run start",
    "test": "npm run lint && npm run test:cli && npm run test:server",
    "lint": "npm run lint:server && npm run lint:client && npm run lint:cli",
    "lint:server": "npm --workspace server run lint",
    "lint:client": "npm --workspace client run lint",
    "lint:cli": "npm --workspace cli run lint",
    "test:cli": "npm --workspace cli run test",
    "test:server": "npm --workspace server run test",
    "format": "npm run format:server && npm run format:client && npm run format:cli",
    "format:cli": "npm --workspace cli run format"
  },
  "devDependencies": {
    "prisma": "^6.19.0"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.53.2"
  }
}
